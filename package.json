{
  "name": "autodex",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "dev:remote": "astro dev --remote",
    "build": "astro build --remote",
    "build:local": "ASTRO_DATABASE_FILE=./local.db astro build",
    "preview": "wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "astro": "astro",
    "sync": "astro sync",
    "db:verify": "astro db verify --remote",
    "db:seed": "astro db execute db/seed.ts --remote",
    "db:push": "astro db push --remote",
    "generate-types": "wrangler types"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.7",
    "@astrojs/db": "^0.20.1",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.1.3",
    "wrangler": "^4.80.0"
  },
  "devDependencies": {
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "0.7.2"
  }
}